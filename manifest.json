{
  "manifest_version": 3,
  "name": "SnapCast Recorder",
  "description": "Record screen with optional camera picture-in-picture and save locally.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "downloads",
    "background",
    "offscreen",
    "tabs",
    "windows"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SnapCast",
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["recorder.html", "recorder.css", "recorder.js", "vendor/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
